    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
        },
        {
            "name": "Ours (main.py)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": [
                "--yaml-cfg",
                "run/args_cfg.yaml",
                "--workload-cfg",
                "run/workloads.yaml"
            ],
            "console": "integratedTerminal",
            "redirectOutput": true,
            "justMyCode": true
        },
        {
            "name": "Baseline (main.py)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": [
                "--yaml-cfg",
                "run/baseline_cfg.yaml",
                "--workload-cfg",
                "run/workloads.yaml"
            ],
            "console": "integratedTerminal",
            "redirectOutput": true,
            "justMyCode": true
        },
        {
            "name": "SOTA (main.py)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": [
                "--yaml-cfg",
                "run/sota_cfg.yaml",
                "--workload-cfg",
                "run/workloads.yaml"
            ],
            "console": "integratedTerminal",
            "redirectOutput": true,
            "justMyCode": true
        },
        {
            "name": "Partition (main.py)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": [
                "--yaml-cfg",
                "run/partition_cfg.yaml",
                "--workload-cfg",
                "run/workloads.yaml"
            ],
            "console": "integratedTerminal",
            "redirectOutput": true,
            "justMyCode": true
        }
    ]
}